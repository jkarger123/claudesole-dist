<?xml version="1.0" encoding="UTF-8"?>
<!--
  ClaudeFather always-on unit (macOS / launchd) -- TEMPLATE.
  Keeps ONE instance's dashboard supervised: launchd restarts it if it dies (KeepAlive), and the
  supervisor runs it as a tmux session on the shared "brain" tmux server so it inherits Full-Disk /
  external-drive access (a bare launchd context gets EPERM on external volumes).

  INSTALL:
    1. Replace the __PLACEHOLDERS__ below (no braces/brackets left behind):
         __LABEL__      reverse-DNS unique id, e.g. com.claudefather.acme   (also the filename)
         __CC_HOME__    absolute path to this framework home (the unzipped claudefather/ dir)
         __CC_CONFIG__  absolute path to this instance's cc.config.json (usually __CC_HOME__/cc.config.json)
         __SESSION__    tmux session name for this instance (must match cc.config "session"; default: claudefather)
         __USER__       the OS account that owns the tmux brain server (whoami)
    2. Save as ~/Library/LaunchAgents/__LABEL__.plist
    3. launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/__LABEL__.plist
       (older macOS: launchctl load -w ~/Library/LaunchAgents/__LABEL__.plist)
    4. Verify: launchctl print gui/$(id -u)/__LABEL__ | grep state   ->  running
  The supervisor (cc-instance-supervise.sh) resolves tmux portably (command -v tmux), so no Homebrew path
  is baked in here.
-->
<plist version="1.0">
<dict>
  <key>Label</key>            <string>__LABEL__</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__CC_HOME__/command-center/cc-instance-supervise.sh</string>
    <string>__CC_CONFIG__</string>
    <string>__SESSION__</string>
  </array>
  <key>RunAtLoad</key>        <true/>
  <key>KeepAlive</key>        <true/>
  <key>WorkingDirectory</key> <string>__CC_HOME__</string>
  <key>StandardOutPath</key>  <string>/tmp/__SESSION__.launchd.out.log</string>
  <key>StandardErrorPath</key><string>/tmp/__SESSION__.launchd.err.log</string>
  <key>ProcessType</key>      <string>Interactive</string>
</dict>
</plist>
