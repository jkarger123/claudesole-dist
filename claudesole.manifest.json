{
  "product": "ClaudeFather",
  "former_name": "Claudesole",
  "version": "0.99.16",
  "description": "Manifest that defines which paths are FRAMEWORK (ship + propagate to every ClaudeFather deployment on update) vs PRESERVE (per-deployment config/data/secrets/learnings -- never overwritten by an update).",
  "framework_paths": [
    "core.sig.json",
    "recovery.pub",
    "cf-appliance-install.sh",
    "cf-update-healer.sh",
    "cf-build-appliance.sh",
    "cf-key-backup.sh",
    "cf-key-restore.sh",
    "docs/RECOVERY.md",
    "docs/HARDENING.md",
    "docs/VAULT.md",
    "docs/APPLIANCE_BRINGUP.md",
    "docs/IP_PROTECTION.md",
    "docs/CREDENTIALS.md",
    "docs/EXTENSIONS.md",
    "docs/CONTEXT_ENGINEERING.md",
    "command-center/server.py",
    "command-center/scan_projects.py",
    "command-center/cc-task",
    "command-center/cc-secure",
    "command-center/cc-instance-supervise.sh",
    "command-center/granola.py",
    "command-center/substack.py",
    "command-center/context.py",
    "command-center/focus.py",
    "command-center/clips.py",
    "command-center/preship.py",
    "command-center/slack.py",
    "command-center/zoom.py",
    "command-center/mesh_stop_hook.py",
    "command-center/cc-session-watchdog.py",
    "command-center/ralph_runner.py",
    "command-center/git-backup.sh",
    "command-center/git-backup-secretscan.py",
    "command-center/static",
    "command-center/update",
    "agents/*/CLAUDE.md",
    "agents/*/tools",
    "agents/*/config.example.json",
    "agents/*/ROTATION_CHECKLIST.md",
    "presets",
    "extensions",
    "cc-init.sh",
    "cc-update.sh",
    "cc-recover.sh",
    "cc-newinstance.sh",
    "install",
    "make-install-package.sh",
    "desktop",
    "claudesole.manifest.json",
    "docs/PACKAGING.md",
    "docs/CHANGELOG.md",
    "docs/FEATURES.md",
    "docs/SMART_FILES.md",
    "docs/CONTROL_CENTER_BLUEPRINT.md",
    "docs/CLAUDE_CODE_REFERENCE.md",
    "docs/SESSIONS_AND_SUDO.md",
    "docs/MEMORY_SKILLS_AGENTS.md",
    "docs/SESSION_HANDOFF_COGNITION_MODULE.md",
    "docs/ROOT_CLAUDE_SLIMDOWN_PLAN.md",
    "docs/MODULE_MAP.md",
    "docs/AGENCY_INTEGRATION.md",
    "docs/PIPELINE_LIVEVIEW.md",
    "docs/SUPERADMIN.md",
    "docs/PROVISIONING.md",
    "superadmin.pub",
    "docs/ICLOUD_STORAGE.md",
    "docs/STORAGE_ARCHITECTURE.md",
    "command-center/CLAUDE.md",
    "command-center/platform_map.json",
    "agents/CLAUDE.md",
    "docs/ARCHITECTURE.md",
    "docs/PRODUCT_PRINCIPLES.md",
    "docs/VISION.md",
    "docs/CAPTURE.md",
    "command-center/vault/CLAUDE.md"
  ],
  "preserve_paths": [
    "cc.config.json",
    "bin",
    "data",
    "command-center/_machines.json",
    "command-center/_components.json",
    "command-center/_routines.json",
    "command-center/_jobs.json",
    "command-center/_ideas.json",
    "command-center/_resumes.json",
    "command-center/_managed_blocks.json",
    "command-center/_backup_state.json",
    "command-center/_extensions.json",
    ".env.claudefather",
    ".mcp.json",
    "command-center/settings.json.bak.*",
    "agents/*/reports",
    "agents/*/config.json",
    "agents/*/rotation_ledger.json",
    "agents/*/baselines",
    "peers.json"
  ],
  "preserve_regions": {
    "_comment": "Within an updated framework file, keep the deployment's content between these markers (so per-deployment learnings survive a framework update).",
    "markers": [
      "<!-- CC:NOTES append-only",
      "<!-- /CC:NOTES -->"
    ]
  },
  "update_model": "This deployment (hptuners) is the dev/master copy: features are added HERE. `cc-update.sh` overlays FRAMEWORK paths from an upstream (a git repo or a directory) onto a target deployment, never touching PRESERVE paths, and splicing back each file's CC:NOTES region. Other ClaudeFather installs run `cc-update.sh <upstream>` to pull your latest features."
}