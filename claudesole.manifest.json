    "command-center/_backup_state.json",
    "command-center/_extensions.json",
    ".env.claudefather",
    ".mcp.json",
    "command-center/settings.json.bak.*",
    "agents/*/reports",
    "agents/*/config.json",
    "agents/*/rotation_ledger.json",
    "agents/*/baselines",
    "peers.json"
  ],
  "never_ship": [
    "secrets",
    "secrets/",
    ".env",
    ".env.*",
    "*.local",
    "_handoffs",
    "deliverables",
    "node_modules",
    "release",
    "_trash",
    "_archive",
    "*.corrupt",
    "*.tmp.*",
    ".DS_Store",
    ".git",
    ".git/",
    "__pycache__",
    "*.pyc",
    "*.log",
    "*.jsonl"
  ],
  "_never_ship_comment": "Paths/patterns that must NEVER be copied into a shipped bundle even when they sit INSIDE a framework_path dir (e.g. extensions/*/secrets/, desktop/node_modules, module _handoffs/, deliverables symlinks to the dev SSD). The single source of truth for the rsync --exclude set used by cc-update.sh, make-install-package.sh, and cc-newinstance.sh. Adding an exclude here protects every copier at once. (deep-audit 2026-07-09 finding 0.4.)",
  "preserve_regions": {
    "_comment": "Within an updated framework file, keep the deployment's content between these markers (so per-deployment learnings survive a framework update).",
    "markers": [
      "<!-- CC:NOTES append-only",
      "<!-- /CC:NOTES -->"
    ]
  },
  "update_model": "The authoring / Mission-Control deployment is the dev/master copy: features are added HERE. `cc-update.sh` overlays FRAMEWORK paths from an upstream (a git repo or a directory) onto a target deployment, never touching PRESERVE paths, and splicing back each file's CC:NOTES region. Other ClaudeFather installs run `cc-update.sh <upstream>` to pull your latest features."
}