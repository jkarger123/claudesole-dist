#!/usr/bin/env python3
"""cc-email -- agent + operator CLI for the Email Archive (the 'email-archive' extension).

Search the operator's archived (exported) email and pull a full message as context, from the terminal -- no
dashboard needed. Resolves the index path from cc.config exactly like the server (email_archive_db / STATE_DIR).
Read-only.

  cc-email ask "<question>" [--no-ai]  BEST for a task: reads only the few most relevant emails and answers
                                       with [#n] citations (~2k tokens on Haiku). --no-ai = retrieval only.
  cc-email search "<query>" [limit]    ranked matches -> "id | date | from | subject" + a snippet line
  cc-email get <id>                    the FULL message (headers + body) -- paste it into your working context
  cc-email thread <id>                 every message in that conversation (pass a message id or a thread id)
  cc-email contacts [n]                top correspondents by volume
  cc-email stats                       index status + counts

Prefer `ask` for a real question -- it does the token-bounded plan->retrieve->answer loop for you, so you
never load the inbox. Use `search`+`get` when you want to read specific messages yourself. Search query =
SQLite FTS5 (bare words AND; "quote phrases"; OR/NOT). To hand a whole email to a Claude session: `get <id>`
and include it, or (in the dashboard) drag a result row onto the session. Read-only.
"""
import sys, os, json, subprocess, time

BASE = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, BASE)
import email_archive


def _claude(prompt):
    """Haiku one-shot on the node's subscription login (no metered key), for the ask-loop's plan + synthesis."""
    try:
        r = subprocess.run(["claude", "--dangerously-skip-permissions", "-p", prompt, "--model", "claude-haiku-4-5"],
                           capture_output=True, text=True, timeout=60, cwd="/tmp")
        return (r.stdout or "").strip() if r.returncode == 0 else None
    except Exception:
        return None


def _load_cc():
    p = os.environ.get("CC_CONFIG")
    if not p:
        home = os.environ.get("CC_HOME") or os.path.dirname(BASE)
        p = os.path.join(home, "cc.config.json")
    try:
        with open(p) as f:
            return json.load(f)
    except Exception:
        return {}


def main():
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help", "help"):
        print(__doc__)
        return 0
    cc = _load_cc()
    email_archive.init({"CC": cc, "STATE_DIR": cc.get("state_dir") or BASE})
    cmd = args[0]

    if cmd == "ask":
        if len(args) < 2:
            print('usage: cc-email ask "<question>" [--no-ai]')
            return 2
        use_ai = "--no-ai" not in args
        a = email_archive.mb_ask(args[1], ask_llm=(_claude if use_ai else None), today=time.strftime("%Y-%m-%d"))
        if not a.get("ok"):
            print("ask failed: " + str(a.get("error", "?")))
            return 1
        if a.get("answer"):
            print(a["answer"] + "\n")
        elif use_ai:
            print("(no synthesized answer -- showing the most relevant emails)\n")
        srcs = a.get("sources", [])
        print("-- sources (%d read, %d considered):" % (len(srcs), a.get("n_considered", 0)))
        for i, s in enumerate(srcs, 1):
            print("  [%d] id=%s | %s | %s" % (i, s.get("rowid"), (s.get("date_str") or "")[:20], (s.get("subject") or "")[:62]))
        return 0

    if cmd == "thread":
        if len(args) < 2:
            print("usage: cc-email thread <id>")
            return 2
        t = email_archive.mb_thread(args[1])
        if not t.get("ok"):
            m = email_archive.mb_get(args[1])                       # maybe a message id -> resolve its thread
            if m.get("ok") and (m.get("message") or {}).get("thread_id"):
                t = email_archive.mb_thread(m["message"]["thread_id"])
        if not t.get("ok"):
            print("no thread: " + str(t.get("error", "?")))
            return 1
        for mm in t.get("messages", []):
            print("id=%s | %s | %s" % (mm.get("rowid"), (mm.get("date_str") or "")[:20],
                                       (mm.get("from_name") or mm.get("sender") or "")[:36]))
        return 0

    if cmd == "contacts":
        lim = int(args[1]) if len(args) > 1 and args[1].isdigit() else 20
        for x in email_archive.mb_contacts(lim).get("contacts", []):
            print("%7d  %-40s %s" % (x.get("n", 0), (x.get("addr") or "")[:40], (x.get("name") or "")[:28]))
        return 0

    if cmd == "stats":
        s = email_archive.mb_stats()
        if not s.get("ready"):
            print("index not ready: " + str(s.get("error", "?")))
            return 1
        print("ready: %s messages indexed" % format(s.get("count", 0), ","))
        return 0

    if cmd == "search":
        if len(args) < 2:
            print('usage: cc-email search "<query>" [limit]')
            return 2
        q = args[1]
        lim = int(args[2]) if len(args) > 2 and args[2].isdigit() else 30
        r = email_archive.mb_search(q, lim)
        if not r.get("ok"):
            print("search failed: " + str(r.get("error", "?")))
            return 1
        res = r.get("results", [])
        if not res:
            print("no matches for " + repr(q))
            return 0
        for m in res:
            print("%s | %s | %s | %s" % (m.get("rowid"), (m.get("date_str") or "")[:24],
                                         (m.get("sender") or "")[:34], (m.get("subject") or "")[:64]))
            snip = (m.get("snip") or "").replace("CCHLA", "[").replace("CCHLB", "]").replace("\n", " ").strip()
            if snip:
                print("    " + snip[:200])
        print("\n(%d shown -- `cc-email get <id>` for the full message)" % len(res))
        return 0

    if cmd == "get":
        if len(args) < 2:
            print("usage: cc-email get <id>")
            return 2
        r = email_archive.mb_get(args[1])
        if not r.get("ok"):
            print("not found: " + str(r.get("error", "?")))
            return 1
        m = r.get("message", {})
        print("Subject: %s" % m.get("subject", ""))
        print("From: %s" % m.get("sender", ""))
        print("To: %s" % m.get("recipients", ""))
        print("Date: %s" % m.get("date_str", ""))
        if m.get("labels"):
            print("Labels: %s" % m.get("labels"))
        print()
        print(m.get("body") or "(no text body)")
        return 0

    print("unknown command: " + cmd)
    print(__doc__)
    return 2


if __name__ == "__main__":
    sys.exit(main())
