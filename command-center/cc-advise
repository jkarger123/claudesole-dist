#!/usr/bin/env python3
"""cc-advise -- cross-vendor advisor (the core partner-call helper).

An independent GPT (Codex on the ChatGPT subscription) reviews a Claude agent's
FINISHED work against its goal and returns a structured second opinion:
verdict + blocking/non-blocking issues + guidance to steer the NEXT task.

Report-only (Codex runs a read-only sandbox), fail-open (if Codex is
unavailable/rate-limited it returns verdict:"skipped" and exit 0, never blocking
the Claude work), budget-guarded (a daily call cap so it stays inside Plus), and
secret-clean (auth lives in ~/.codex/auth.json; tokens are never echoed).

Two ways to feed it context:
  1. FILE mode (standalone / Ralph):   --goal <f> --deliverable <f> [--summary <f>]
  2. PAYLOAD mode (Command Center v1):  --payload <file|->    (a pre-assembled
     context blob; use "-" to read it from stdin). The server assembles a
     session's recent messages + latest deliverables and pipes it in here.

Graduated from conceptsandideas/OmniAgent/working/ per CROSS_VENDOR_ADVISOR_SPEC
.md (7b). The Command Center endpoints (/api/advise, /api/advise-inject) shell
out to this file.

Usage:
  cc-advise --payload -  --repo <dir> [--verify] [--json]
  cc-advise --goal <f> --deliverable <f> [--summary <f>] [--repo <dir>] [--json]
"""
import argparse, json, os, subprocess, sys, tempfile, datetime, textwrap

CODEX = os.path.expanduser("~/.npm-global/bin/codex")
MAX_INLINE = 60000  # chars of a deliverable/payload to inline before truncating

SCHEMA = {
    "type": "object", "additionalProperties": False,
    "properties": {
        "verdict": {"type": "string", "enum": ["ship", "revise", "block"]},
        "blocking": {"type": "array", "items": {
            "type": "object", "additionalProperties": False,
            "properties": {"issue": {"type": "string"},
                           "location": {"type": "string"},
                           "why": {"type": "string"}},
            "required": ["issue", "location", "why"]}},
        "nonblocking": {"type": "array", "items": {"type": "string"}},
        "next_task_guidance": {"type": "string"},
    },
    "required": ["verdict", "blocking", "nonblocking", "next_task_guidance"],
}

# DIRECTOR schema (mode=direct_next): the reviewer becomes a PLANNER that decides the campaign's next loop.
DIRECTOR_SCHEMA = {
    "type": "object", "additionalProperties": False,
    "properties": {
        "status": {"type": "string", "enum": ["continue", "done"]},
        "assessment": {"type": "string"},   # brief: what the finished loop produced vs the north-star goal
        "next_loop": {
            "type": "object", "additionalProperties": False,
            "properties": {
                "goal": {"type": "string"},
                "checklist": {"type": "array", "items": {"type": "string"}},
                "rationale": {"type": "string"},
            },
            "required": ["goal", "checklist", "rationale"],
        },
        "done_reason": {"type": "string"},   # if status==done, why the north-star goal is met
    },
    "required": ["status", "assessment", "next_loop", "done_reason"],
}

DIRECTOR = textwrap.dedent("""\
    You are the DIRECTOR of an autonomous engineering campaign -- an independent
    senior engineer from a DIFFERENT AI vendor than the agents doing the work. A
    Claude agent just ran an autonomous loop to completion (its output is below);
    you also have the campaign's NORTH-STAR GOAL and the history of prior loops.

    Decide the campaign's next move, skeptically and decisively:
      - If the north-star goal is genuinely ACHIEVED, set status="done" and explain
        in done_reason (be honest -- don't declare done to stop early, and don't
        churn make-work loops to avoid finishing).
      - Otherwise set status="continue" and specify the NEXT loop: a concrete,
        single-focus `goal` (one line) plus a `checklist` of 2-6 verifiable items a
        Claude agent will execute, and a short `rationale` for why this is the right
        next step given what just finished. Build on the finished work; do not
        repeat it. Prefer the highest-leverage next step toward the north-star.

    You may READ the repo. You must NOT edit anything -- you plan, Claude builds.
    Return ONLY the JSON object required by the output schema.
    """)

REVIEWER = textwrap.dedent("""\
    You are an independent senior engineer from a DIFFERENT AI vendor than the
    agent that produced the work below. A Claude agent just finished a task and
    summarized it. Review the FINISHED work against the stated goal --
    skeptically. Assume the author's own model rubber-stamped its own work; your
    value is catching what it missed, not agreeing.

    You may READ the provided material (and files under the repo root if one is
    given). You must NOT edit anything, write code, or open a PR -- report only.

    Judge it against the GOAL, not against your own idea of a different task.
    Be concrete: cite the specific claim, section, or file:line. Do not pad, do
    not invent problems -- if it is genuinely good, say so with empty blocking.

    Return ONLY the JSON object required by the output schema:
      verdict            "ship" | "revise" | "block"
      blocking           [{issue, location, why}]  -- defects that must be fixed
      nonblocking        [{suggestion string}]     -- improvements, not blockers
      next_task_guidance one short paragraph directing the NEXT task -- what to
                         prioritize, watch for, or do differently ({mode_note}).
    """)


VERIFY_CLAUSE = textwrap.dedent("""\

    VERIFICATION MANDATE (do not skip). This deliverable may assert "FACT" claims
    that are actually inferences. Do NOT trust the report's prose. For every
    load-bearing claim, OPEN the actual deliverable files under the repo root and
    independently re-check it: recompute any derived count, re-read the referenced
    JSON/evidence records, and confirm the report's numbers match the files. In
    your reasoning, state what you verified against a file vs what you could only
    take on the report's word. Any load-bearing FACT you cannot substantiate from
    the provided files is a BLOCKING issue (mislabeled inference / unverifiable).
    A clean "ship" is warranted ONLY if you actually opened the files and they
    corroborate the report.
    """)


def _load(val):
    """A --goal/--summary/--deliverable value: a readable file path, else literal."""
    if val and os.path.isfile(val):
        return open(val, encoding="utf-8", errors="replace").read()
    return val or ""


def _budget_ok(path, cap):
    today = datetime.date.today().isoformat()
    st = {"date": today, "count": 0}
    if os.path.isfile(path):
        try:
            st = json.load(open(path))
        except Exception:
            pass
    if st.get("date") != today:
        st = {"date": today, "count": 0}
    if st["count"] >= cap:
        return False, st["count"]
    st["count"] += 1
    try:
        json.dump(st, open(path, "w"))
    except Exception:
        pass
    return True, st["count"]


def _emit_result(d, result_file):
    """Persist the final verdict to --result-file (atomic) so a caller polling the file always sees a result,
    even on a skip/failure -- this is what keeps the Command Center panel from hanging forever."""
    if not result_file:
        return
    try:
        tmp = result_file + ".tmp"
        json.dump(d, open(tmp, "w"))
        os.replace(tmp, result_file)
    except Exception:
        pass


def _skip(reason, as_json, result_file=None):
    out = {"verdict": "skipped", "reason": reason}
    _emit_result(out, result_file)
    print(json.dumps(out) if as_json else "[cc-advise] SKIPPED: %s" % reason)
    return 0


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--goal", default="", help="task goal/contract (file or string)")
    ap.add_argument("--deliverable", default="", help="finished work (file or string)")
    ap.add_argument("--summary", default="", help="agent's final summary (file or string)")
    ap.add_argument("--payload", default="", help="pre-assembled context blob (file, or '-' for stdin)")
    ap.add_argument("--repo", default="", help="repo root the reviewer may read")
    ap.add_argument("--model", default="gpt-5.5")
    ap.add_argument("--effort", default="medium",
                    choices=["none", "minimal", "low", "medium", "high", "xhigh"])
    ap.add_argument("--mode", default="review_and_steer",
                    choices=["review_and_steer", "review_only", "direct_next"])
    ap.add_argument("--max-calls-per-day", type=int, default=40)
    ap.add_argument("--budget-file",
                    default=os.path.join(os.path.dirname(os.path.abspath(__file__)),
                                         ".cc-advise-budget.json"))
    ap.add_argument("--verify", action="store_true",
                    help="rigor mode: force independent verification of load-bearing FACT claims")
    ap.add_argument("--json", action="store_true", help="print raw JSON verdict")
    ap.add_argument("--stream", action="store_true",
                    help="TRANSPARENT mode: let codex stream its work to this terminal live (do not capture); "
                         "for running inside a watchable tmux tab. Writes the verdict to --result-file.")
    ap.add_argument("--result-file", default="",
                    help="write the final structured verdict JSON here (atomic) -- for a caller polling for it")
    args = ap.parse_args()

    # PAYLOAD mode (Command Center) vs FILE mode (standalone/Ralph) -- one is required.
    if args.payload:
        payload_text = sys.stdin.read() if args.payload == "-" else _load(args.payload)
    elif args.goal and args.deliverable:
        payload_text = None
    else:
        ap.error("provide --payload, or both --goal and --deliverable")

    rf = args.result_file
    # Check the reviewer is even available BEFORE spending budget -- else a mis-configured node (no Codex)
    # burns its whole daily cap on skipped attempts (only real invocations should count).
    if not os.path.isfile(CODEX):
        return _skip("codex CLI not found at %s" % CODEX, args.json, rf)

    ok, n = _budget_ok(args.budget_file, args.max_calls_per_day)
    if not ok:
        return _skip("daily advisor cap reached (%d)" % n, args.json, rf)

    if payload_text is not None:
        if len(payload_text) > MAX_INLINE:
            payload_text = payload_text[:MAX_INLINE] + "\n\n[...truncated for review...]"
        stdin_payload = payload_text
    else:
        goal, deliverable, summary = _load(args.goal), _load(args.deliverable), _load(args.summary)
        if len(deliverable) > MAX_INLINE:
            deliverable = deliverable[:MAX_INLINE] + "\n\n[...truncated for review...]"
        stdin_payload = (
            "=== GOAL / ACCEPTANCE CONTRACT ===\n%s\n\n"
            "=== AGENT'S FINAL SUMMARY ===\n%s\n\n"
            "=== FINISHED DELIVERABLE ===\n%s\n" % (goal, summary or "(none provided)", deliverable)
        )
    if args.repo:
        stdin_payload = ("(You may also read files under repo root: %s)\n\n" % args.repo) + stdin_payload

    director = (args.mode == "direct_next")
    if director:
        prompt = DIRECTOR
        active_schema = DIRECTOR_SCHEMA
    else:
        mode_note = ("give concrete next-task guidance" if args.mode == "review_and_steer"
                     else "leave next_task_guidance empty; this is review-only")
        prompt = REVIEWER.replace("{mode_note}", mode_note)
        active_schema = SCHEMA
    if args.verify:
        prompt += VERIFY_CLAUSE

    if args.stream:   # TRANSPARENT: show the operator what the director/reviewer is doing before it starts
        if director:
            print("=== Campaign DIRECTOR (external GPT: %s) ===" % args.model)
            print("Assessing the finished loop against the north-star goal and deciding the next loop.\n"
                  "Live director output follows. (read-only sandbox.)\n", flush=True)
        else:
            print("=== Third-party review (external GPT: %s%s) ===" % (
                args.model, ", VERIFY mode" if args.verify else ""))
            print("Reviewing the session's recent work against its goal. Live reviewer output follows.\n"
                  "(read-only sandbox -- the reviewer can read the repo but cannot change anything)\n", flush=True)

    with tempfile.TemporaryDirectory() as td:
        schema_f = os.path.join(td, "schema.json")
        last_f = os.path.join(td, "last.json")
        json.dump(active_schema, open(schema_f, "w"))
        cmd = [CODEX, "exec", "--ephemeral", "--skip-git-repo-check",
               "-s", "read-only", "-m", args.model,
               "-c", 'model_reasoning_effort="%s"' % args.effort,
               "--output-schema", schema_f, "-o", last_f, prompt]
        if args.repo:
            cmd[3:3] = ["-C", args.repo]  # insert working root
        try:
            # stream mode: inherit stdout/stderr so codex's work is VISIBLE live in the tmux tab.
            # non-stream: capture (r.stderr used only to note presence on a parse failure).
            r = subprocess.run(cmd, input=stdin_payload, text=True,
                               capture_output=(not args.stream), timeout=300)
        except Exception as e:  # fail-open: never block the Claude work
            return _skip("codex call failed: %s" % e, args.json, rf)
        try:
            verdict = json.load(open(last_f))
        except Exception:
            # Secret-clean (spec 6): NEVER emit raw codex stderr anywhere -- it can carry local paths, auth
            # diagnostics, or command args. We log only whether stderr was present, never its contents.
            sys.stderr.write("[cc-advise] no structured output from the reviewer (stderr present: %s)\n"
                             % bool(((getattr(r, "stderr", "") or "")).strip()))
            return _skip("no structured output from the reviewer", args.json, rf)

    _emit_result(verdict, rf)
    if args.json:
        print(json.dumps(verdict, indent=2))
        return 0
    _pretty(verdict)
    return 0


def _pretty(v):
    if "status" in v and "next_loop" in v:   # director result (mode=direct_next)
        print("\nCAMPAIGN DIRECTOR (external, gpt-5.5) -- STATUS: %s\n" % str(v.get("status", "?")).upper())
        if v.get("assessment"): print("Assessment: %s\n" % v["assessment"])
        if v.get("status") == "done":
            print("CAMPAIGN DONE: %s" % (v.get("done_reason") or "(goal met)")); print(); return
        nl = v.get("next_loop") or {}
        print("NEXT LOOP goal: %s" % nl.get("goal", ""))
        print("Checklist:")
        for it in (nl.get("checklist") or []): print("  - [ ] %s" % it)
        if nl.get("rationale"): print("Rationale: %s" % nl["rationale"])
        print(); return
    icon = {"ship": "SHIP", "revise": "REVISE", "block": "BLOCK"}.get(v.get("verdict"), v.get("verdict", "?"))
    print("\nGPT ADVISOR (external, gpt-5.5) -- VERDICT: %s\n" % icon)
    bl = v.get("blocking") or []
    print("BLOCKING (%d):" % len(bl))
    for b in bl:
        print("  - %s" % b.get("issue", ""))
        if b.get("location"): print("      @ %s" % b["location"])
        if b.get("why"): print("      why: %s" % b["why"])
    if not bl: print("  (none)")
    nb = v.get("nonblocking") or []
    print("\nNON-BLOCKING (%d):" % len(nb))
    for s in nb: print("  - %s" % s)
    if not nb: print("  (none)")
    g = v.get("next_task_guidance") or ""
    if g.strip():
        print("\nGUIDANCE FOR NEXT TASK (weigh it -- Claude holds the pen):")
        print(textwrap.fill(g, 88, initial_indent="  ", subsequent_indent="  "))
    print()


if __name__ == "__main__":
    sys.exit(main())
