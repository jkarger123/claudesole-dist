#!/usr/bin/env python3
"""cc-ralph -- create/launch a Ralph loop that PINGS YOU when it finishes.

Run it from INSIDE your session (an agent's tmux) so the loop records who to notify: when the loop completes, a
"your loop finished" message is delivered back into your session automatically.

  cc-ralph new <name> [goal words...]   # create + launch a loop; records THIS session as the notify target
  cc-ralph launch <name>                # (re)launch an existing loop (keeps its recorded notify target)
  cc-ralph restart <name>               # stop it + relaunch it (resumes from progress; picks up new runner code)
  cc-ralph halt <name>                  # graceful stop (finishes the current iteration, then stops)
  cc-ralph kill <name>                  # immediate stop (terminates the current iteration now)
  cc-ralph pause <name> | resume <name> # pause / resume between iterations
  cc-ralph list                         # active loops + state
"""
import json, os, subprocess, sys, time, urllib.request

BASE = os.path.dirname(os.path.abspath(__file__))
HOME = os.path.dirname(BASE)

def _cfg():
    p = os.environ.get("CC_CONFIG") or os.path.join(os.environ.get("CC_HOME") or HOME, "cc.config.json")
    try: return json.load(open(p))
    except Exception: return {}

def _api(path, body=None, method="POST"):
    c = _cfg(); port = c.get("port") or int(os.environ.get("HPCC_PORT") or 8799); tok = c.get("auth_token") or ""
    data = json.dumps(body).encode() if body is not None else None
    req = urllib.request.Request("http://127.0.0.1:%s%s" % (port, path), data=data,
        headers={"Content-Type": "application/json", "Cookie": "cc_auth=%s" % tok}, method=method)
    return json.loads(urllib.request.urlopen(req, timeout=30).read().decode())

def _my_session():
    """The tmux session this command runs inside (= the agent to ping). Keeps the inherited $TMUX on purpose."""
    try:
        r = subprocess.run(["/opt/homebrew/bin/tmux", "display-message", "-p", "#S"], capture_output=True, text=True, timeout=5)
        return r.stdout.strip() if r.returncode == 0 else ""
    except Exception: return ""

def main():
    a = sys.argv[1:]
    if not a: print(__doc__); return 0
    cmd = a[0]
    if cmd in ("new", "create"):
        if len(a) < 2: print("usage: cc-ralph new <name> [goal...]"); return 1
        name = a[1]; goal = " ".join(a[2:]); ns = _my_session()
        r = _api("/api/ralph-create", {"name": name, "goal": goal, "cwd": os.getcwd(), "notify_session": ns})
        if not r.get("ok"): print("create failed: " + str(r.get("error"))); return 1
        r2 = _api("/api/ralph-launch", {"name": name})
        if not r2.get("ok"): print("created but launch failed: " + str(r2.get("error"))); return 1
        print("created + launched loop '%s'." % name + (
            " It will PING THIS session (%s) when it finishes." % ns if ns
            else " (No tmux session detected -- run this from inside your session to be pinged on completion.)"))
    elif cmd == "launch":
        if len(a) < 2: print("usage: cc-ralph launch <name>"); return 1
        print(json.dumps(_api("/api/ralph-launch", {"name": a[1]})))
    elif cmd in ("halt", "kill", "pause", "resume"):
        if len(a) < 2: print("usage: cc-ralph %s <name>" % cmd); return 1
        r = _api("/api/ralph-control", {"name": a[1], "action": cmd})
        print(("%s -> %s" % (cmd, a[1])) if r.get("ok") else ("%s failed: %s" % (cmd, r.get("error"))))
        return 0 if r.get("ok") else 1
    elif cmd == "restart":
        if len(a) < 2: print("usage: cc-ralph restart <name>"); return 1
        name = a[1]
        r = _api("/api/ralph-control", {"name": name, "action": "kill"})   # immediate stop (loop resumes from progress.md)
        if not r.get("ok") and "no such" in str(r.get("error", "")).lower():
            print("no such loop: " + name); return 1
        for _ in range(15):                                                # wait for the runner session to actually die
            time.sleep(1)
            try:
                if not any(l.get("name") == name and l.get("alive") for l in (_api("/api/ralph", None, "GET") or [])): break
            except Exception: break
        r2 = _api("/api/ralph-launch", {"name": name})
        if r2.get("ok"):
            print("restarted '%s' -- resumes from its saved progress; both the runner and the live-iteration tab are up." % name)
        else:
            print("stopped but relaunch failed: " + str(r2.get("error"))); return 1
        return 0
    elif cmd == "list":
        try:
            r = _api("/api/ralph", None, "GET")
            loops = r.get("loops") if isinstance(r, dict) else (r if isinstance(r, list) else [])
            if not loops: print("(no active loops)")
            for lp in loops:
                print("  %-24s %-10s %s" % (lp.get("name", "?"), lp.get("state", "?"),
                      ("-> pings " + (lp.get("config", {}).get("notify_session") or "(nobody)")) if lp.get("config") else ""))
        except Exception as e:
            print("list failed (%s) -- use the Ralph lens in the dashboard" % str(e)[:60])
    else:
        print(__doc__)
    return 0

if __name__ == "__main__":
    sys.exit(main())
