#!/usr/bin/env python3
"""cc-review -- an independent AI review of your framework changes BEFORE they ship to the fleet.

A bad framework change propagates to EVERY node, so this is the highest-leverage safety point. It runs the
code-reviewer subagent (headless, on the node subscription) over your current git diff -- the reviewer reads the
REAL repo for context, not just the patch -- and prints a VERDICT (PASS / CONCERNS / BLOCK) plus concrete findings.

  cc-review            review `git diff HEAD` (uncommitted, includes staged)
  cc-review --deep     ALSO run security-auditor in parallel (a mini review workflow; worst verdict wins)
  cc-review --staged   review only staged changes (git diff --cached)

Exit code is 2 on BLOCK (so a ship script / autonomous job can gate on it), else 0.
"""
import sys, os, json, subprocess, urllib.request

BASE = os.path.dirname(os.path.abspath(__file__))
HOME = os.path.dirname(BASE)
try:
    sys.path.insert(0, BASE)
    import cc_resolve as _ccr
    def _resolve_cfg_path():
        _p, _e = _ccr.resolve_config_path()
        if _e:
            sys.stderr.write(_e + "\n"); sys.exit(3)
        return _p
except Exception:
    def _resolve_cfg_path():
        return os.environ.get("CC_CONFIG") or os.path.join(os.path.dirname(BASE), "cc.config.json")


def _cfg():
    p = _resolve_cfg_path()
    try:
        with open(p) as f:
            return json.load(f)
    except Exception:
        return {}


def main():
    args = sys.argv[1:]
    if "-h" in args or "--help" in args:
        print(__doc__)
        return 0
    cmd = ["git", "-C", HOME, "diff"] + (["--cached"] if "--staged" in args else ["HEAD"])
    try:
        diff = subprocess.run(cmd, capture_output=True, text=True, timeout=30).stdout
    except Exception as e:
        print("git diff failed: " + str(e)[:120])
        return 1
    if not diff.strip():
        print("No changes to review (git diff is empty).")
        return 0
    cc = _cfg(); port = cc.get("port") or int(os.environ.get("HPCC_PORT") or 8799); tok = cc.get("auth_token") or ""
    deep = "--deep" in args
    body = json.dumps({"diff": diff, "deep": deep, "label": "cc-review"}).encode()
    req = urllib.request.Request("http://127.0.0.1:%s/api/review-diff" % port, data=body,
                                 headers={"Content-Type": "application/json", "Cookie": "cc_auth=%s" % tok})
    print("Reviewing %d chars of diff%s ... (the reviewer reads the repo; ~30-150s)" % (len(diff), " + security" if deep else ""))
    try:
        d = json.loads(urllib.request.urlopen(req, timeout=280).read().decode())
    except Exception as e:
        print("review failed (is the local server up?): " + str(e)[:140])
        return 1
    print("\n=== VERDICT: %s ===" % (d.get("verdict", "?")))
    for r in d.get("reviews", []):
        tag = "%s%s" % (r.get("verdict"), (" $%.4f" % r["cost"] if r.get("cost") else ""))
        print("\n--- %s (%s) ---" % (r.get("agent"), tag))
        print((r.get("text") or "").strip())
    return 2 if (d.get("verdict") or "").upper() == "BLOCK" else 0


if __name__ == "__main__":
    sys.exit(main())
