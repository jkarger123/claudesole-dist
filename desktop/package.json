{
  "name": "claudefather-desktop",
  "version": "0.1.2",
  "description": "ClaudeFather Desktop — an Electron shell that wraps your existing ClaudeFather web dashboard AND a real Chromium browser, so your AI can (with consent) see what you browse. Loads your own self-hosted server; never forks it.",
  "private": true,
  "license": "UNLICENSED",
  "main": "main.js",
  "author": "ClaudeFather",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:all": "electron-builder -mw",
    "pack": "electron-builder --dir",
    "release:mac": "electron-builder --mac --publish always",
    "release:win": "electron-builder --win --publish never"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.claudefather.desktop",
    "productName": "ClaudeFather Desktop",
    "artifactName": "ClaudeFather-Desktop-${arch}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "jkarger123",
        "repo": "claudesole-dist",
        "releaseType": "release"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "dashboard-preload.js",
      "renderer/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ]
    },
    "win": {
      "artifactName": "ClaudeFather-Desktop-Setup.${ext}",
      "target": [
        { "target": "nsis", "arch": ["x64", "arm64"] }
      ]
    },
    "dmg": {
      "title": "ClaudeFather Desktop"
    }
  }
}
